{
  "info": {
    "name": "ShopEase E-Commerce API Testing",
    "description": "API test collection for E-Commerce web application. Covers User Auth, Products, Cart, Orders, and Payments. Tester: Alok Thokale",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "item": [
    {
      "name": "1. User Authentication",
      "item": [
        {
          "name": "TC-API-01 Register User (Valid Data)",
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "url": { "raw": "https://api.shopease.com/v1/auth/register" },
            "body": {
              "mode": "raw",
              "raw": "{\n  \"full_name\": \"Alok Thokale\",\n  \"email\": \"alok@test.com\",\n  \"password\": \"Test@1234\",\n  \"mobile\": \"9876543210\"\n}"
            }
          },
          "response": [],
          "_postman_previewlanguage": "json",
          "status": "Expected: 201 Created",
          "expectedResponse": {
            "status": 201,
            "body": { "message": "User registered successfully", "user_id": 101 }
          }
        },
        {
          "name": "TC-API-02 Register User (Duplicate Email)",
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "url": { "raw": "https://api.shopease.com/v1/auth/register" },
            "body": {
              "mode": "raw",
              "raw": "{\n  \"full_name\": \"Test User\",\n  \"email\": \"alok@test.com\",\n  \"password\": \"Test@1234\",\n  \"mobile\": \"9876543211\"\n}"
            }
          },
          "status": "Expected: 409 Conflict"
        },
        {
          "name": "TC-API-03 Login (Valid Credentials)",
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "url": { "raw": "https://api.shopease.com/v1/auth/login" },
            "body": {
              "mode": "raw",
              "raw": "{\n  \"email\": \"alok@test.com\",\n  \"password\": \"Test@1234\"\n}"
            }
          },
          "status": "Expected: 200 OK + token"
        },
        {
          "name": "TC-API-04 Login (Wrong Password)",
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "url": { "raw": "https://api.shopease.com/v1/auth/login" },
            "body": {
              "mode": "raw",
              "raw": "{\n  \"email\": \"alok@test.com\",\n  \"password\": \"WrongPass\"\n}"
            }
          },
          "status": "Expected: 401 Unauthorized"
        }
      ]
    },
    {
      "name": "2. Products",
      "item": [
        {
          "name": "TC-API-05 Get All Products",
          "request": {
            "method": "GET",
            "url": { "raw": "https://api.shopease.com/v1/products" }
          },
          "status": "Expected: 200 OK"
        },
        {
          "name": "TC-API-06 Get Product by ID (Valid)",
          "request": {
            "method": "GET",
            "url": { "raw": "https://api.shopease.com/v1/products/101" }
          },
          "status": "Expected: 200 OK"
        },
        {
          "name": "TC-API-07 Get Product by ID (Invalid)",
          "request": {
            "method": "GET",
            "url": { "raw": "https://api.shopease.com/v1/products/9999" }
          },
          "status": "Expected: 404 Not Found"
        },
        {
          "name": "TC-API-08 Search Products by Keyword",
          "request": {
            "method": "GET",
            "url": { "raw": "https://api.shopease.com/v1/products?search=laptop" }
          },
          "status": "Expected: 200 OK with filtered results"
        }
      ]
    },
    {
      "name": "3. Cart",
      "item": [
        {
          "name": "TC-API-09 Add Item to Cart",
          "request": {
            "method": "POST",
            "header": [
              { "key": "Content-Type", "value": "application/json" },
              { "key": "Authorization", "value": "Bearer {{token}}" }
            ],
            "url": { "raw": "https://api.shopease.com/v1/cart" },
            "body": {
              "mode": "raw",
              "raw": "{\n  \"product_id\": 101,\n  \"quantity\": 2\n}"
            }
          },
          "status": "Expected: 200 OK"
        },
        {
          "name": "TC-API-10 Get Cart Items",
          "request": {
            "method": "GET",
            "header": [{ "key": "Authorization", "value": "Bearer {{token}}" }],
            "url": { "raw": "https://api.shopease.com/v1/cart" }
          },
          "status": "Expected: 200 OK"
        },
        {
          "name": "TC-API-11 Add Item – Out of Stock",
          "request": {
            "method": "POST",
            "header": [
              { "key": "Content-Type", "value": "application/json" },
              { "key": "Authorization", "value": "Bearer {{token}}" }
            ],
            "url": { "raw": "https://api.shopease.com/v1/cart" },
            "body": {
              "mode": "raw",
              "raw": "{\n  \"product_id\": 205,\n  \"quantity\": 1\n}"
            }
          },
          "status": "Expected: 400 Bad Request – Out of stock"
        }
      ]
    },
    {
      "name": "4. Orders",
      "item": [
        {
          "name": "TC-API-12 Place Order",
          "request": {
            "method": "POST",
            "header": [
              { "key": "Content-Type", "value": "application/json" },
              { "key": "Authorization", "value": "Bearer {{token}}" }
            ],
            "url": { "raw": "https://api.shopease.com/v1/orders" },
            "body": {
              "mode": "raw",
              "raw": "{\n  \"address_id\": 3,\n  \"payment_method\": \"UPI\"\n}"
            }
          },
          "status": "Expected: 201 Created"
        },
        {
          "name": "TC-API-13 Get Order History",
          "request": {
            "method": "GET",
            "header": [{ "key": "Authorization", "value": "Bearer {{token}}" }],
            "url": { "raw": "https://api.shopease.com/v1/orders" }
          },
          "status": "Expected: 200 OK"
        },
        {
          "name": "TC-API-14 Get Order by ID (Valid)",
          "request": {
            "method": "GET",
            "header": [{ "key": "Authorization", "value": "Bearer {{token}}" }],
            "url": { "raw": "https://api.shopease.com/v1/orders/1023" }
          },
          "status": "Expected: 200 OK"
        },
        {
          "name": "TC-API-15 Place Order with Empty Cart",
          "request": {
            "method": "POST",
            "header": [
              { "key": "Content-Type", "value": "application/json" },
              { "key": "Authorization", "value": "Bearer {{token}}" }
            ],
            "url": { "raw": "https://api.shopease.com/v1/orders" },
            "body": {
              "mode": "raw",
              "raw": "{\n  \"address_id\": 3,\n  \"payment_method\": \"UPI\"\n}"
            }
          },
          "status": "Expected: 400 Bad Request – Cart is empty"
        }
      ]
    }
  ],
  "variable": [
    { "key": "token", "value": "your_jwt_token_here", "description": "JWT auth token from login response" }
  ]
}
